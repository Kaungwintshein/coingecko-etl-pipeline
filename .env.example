# CoinGecko works without an API key for this demo.
# If you have a demo/pro key, set it here and the extractor will send it securely.
COINGECKO_API_KEY=

# API settings
COIN_ID=bitcoin
VS_CURRENCY=usd
MARKET_CHART_DAYS=30
API_TIMEOUT_SECONDS=30

# Local warehouse settings used by docker-compose Postgres
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=crypto_warehouse
POSTGRES_USER=warehouse_user
POSTGRES_PASSWORD=warehouse_password

# Pipeline storage paths
RAW_DATA_DIR=data/raw
PROCESSED_DATA_DIR=data/processed
